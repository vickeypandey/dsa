#include <stdio.h>
#include <string.h>

struct Symbol {
    char name[20];
    char type[10];
    int address;
} table[10];

int count = 0;

void insert(char *n, char *t, int a) {
    strcpy(table[count].name, n);
    strcpy(table[count].type, t);
    table[count].address = a;
    count++;
}

void display() {
    printf("\nName\tType\tAddress\n");
    for(int i=0; i<count; i++)
        printf("%s\t%s\t%d\n", table[i].name, table[i].type, table[i].address);
}

int main() {
    insert("x", "int", 1001);
    insert("y", "float", 1005);
    display();
    return 0;
}

