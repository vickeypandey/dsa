//JobSequence with Deadline
#include <stdio.h>

struct Job{
    int id, deadline, profit;
};

void sort(struct Job arr[], int n){
    for(int i=0;i<n-1;i++){
        for(int j=i+1;j<n;j++){
            if(arr[i].profit < arr[j].profit){
                struct Job temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
            }
        }
    }
}

int main(){
    struct Job arr[100];
    int n;

    printf("Enter number of jobs: ");
    scanf("%d",&n);

    printf("Enter id, deadline, profit:\n");
    for(int i=0;i<n;i++)
        scanf("%d %d %d",&arr[i].id,&arr[i].deadline,&arr[i].profit);

    sort(arr,n);

    int slot[100] = {0};
    int totalProfit = 0;

    for(int i=0;i<n;i++){
        for(int j=arr[i].deadline;j>0;j--){
            if(slot[j]==0){
                slot[j] = arr[i].id;
                totalProfit += arr[i].profit;
                break;
            }
        }
    }

    printf("Total Profit = %d", totalProfit);
    return 0;
}
//job sequence ends

//Longest Common Subsequence (LCS)
#include <stdio.h>
#include <string.h>

int main(){
    char X[100], Y[100];
    int L[100][100];

    printf("Enter first string: ");
    scanf("%s",X);
    printf("Enter second string: ");
    scanf("%s",Y);

    int m = strlen(X);
    int n = strlen(Y);

    for(int i=0;i<=m;i++){
        for(int j=0;j<=n;j++){
            if(i==0 || j==0)
                L[i][j]=0;
            else if(X[i-1]==Y[j-1])
                L[i][j]=1+L[i-1][j-1];
            else
                L[i][j]=(L[i-1][j] > L[i][j-1]) ? L[i-1][j] : L[i][j-1];
        }
    }

    printf("Length of LCS = %d",L[m][n]);
    return 0;
}
//LongestCommon Subsequence ends

